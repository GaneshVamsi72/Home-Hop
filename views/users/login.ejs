<% layout('layouts/BaseLayout.ejs') %>

<div class="d-flex flex-column justify-content-center align-items-center my-5">
    <div class="auth-card shadow-sm border-0 px-5 py-4">
        <h3 class="text-center mb-4">Login</h3>

        <form action="/login" method="POST" class="needs-validation" novalidate>
            <div class="mb-3">
                <label class="form-label">Username</label> 
                <input type="text" name="username" class="form-control" placeholder="Enter username" required>
                <div class="invalid-feedback">Username is required!</div>
            </div>

            <div class="mb-3">
                <label class="form-label">Password</label>
                <input type="password" name="password" class="form-control" placeholder="Enter password" required>
                <div class="invalid-feedback">Password is required!</div>
            </div>

            <button class="btn w-100 text-white" style="background-color:#fe424d;">Login</button>
        </form>

        <p class="text-center mt-3 text-muted">
            Don't have an account?
            <a href="/signup" class="text-decoration-none">Sign Up</a>
        </p>
    </div>
</div>

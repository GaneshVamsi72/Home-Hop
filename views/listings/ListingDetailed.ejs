<% layout('layouts/BaseLayout.ejs') %>

<style>
    .card:hover {
        opacity: 1;
    }
</style>

<h3 style="text-align: center;"><%= listing.title %></h3>

<div class="container">
    <div class="row">
        <div class="col-md-8 offset-md-2 mb-3">
            <div class="card mb-3">
                <div class="d-flex justify-content-center">
                    <img class="card-img-top" style="width: 20rem" src=<%= listing.image %> alt=<%= listing.title %>>
                </div>
            </div>
            
            <p class="mb-1"> <b><%= listing.type %></b> In <%= listing.location %>, <%= listing.country %></p>
            <p class="mt-3 mb-2">₹<%= listing.price.toLocaleString('en-IN') %> / night</p> <!-- Ctrl + Alt + 4 -> ₹ -->

            <hr>
            <p><%= listing.description %></p>
            <hr>

            <p><b>Amenities</b></p>
            <ul>
                <% if (listing.amenities && listing.amenities.length) { %>
                    <% listing.amenities.forEach(function(a) { %>
                        <li class="py-1"><%= a %></li>
                    <% }) %>
                <% } %>
            </ul>

            <hr>

            <div>
                <h4>Leave a Review</h4>

                <form action="/listings/<%= listing._id %>/reviews" method="POST" novalidate class="needs-validation">
                    <div>
                        <label class="mb-2">Rating:</label>
                        <fieldset class="starability-slot">
                            <input type="radio" id="first-rate1" name="review[rating]" value="1" checked/>
                            <label for="first-rate1" title="Terrible">1 star</label>
                            <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                            <label for="first-rate2" title="Not good">2 stars</label>
                            <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                            <label for="first-rate3" title="Average">3 stars</label>
                            <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                            <label for="first-rate4" title="Very good">4 stars</label>
                            <input type="radio" id="first-rate5" name="review[rating]" value="5"/>
                            <label for="first-rate5" title="Amazing">5 stars</label>
                        </fieldset>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Comment:</label>
                        <textarea name="review[comment]" class="form-control" rows="4" required></textarea>
                        <div class="invalid-feedback">Feedback is required!</div>
                    </div>

                    <button class="btn btn-dark">Add Review</button>
                </form>
            </div>

            <hr>

            <% 
                let avgRating = 0;

                if (listing.reviews.length) {
                    avgRating = listing.reviews.reduce((sum, review) => sum + review.rating, 0) / listing.reviews.length;
                }
            %>

            <div class="text-center">
                <% if (listing.reviews.length) { %>
                        <h3>Average Rating</h3>
                        <p class="badge bg-dark text-white">
                            <%= avgRating.toFixed(1) %> ⭐
                        </p>

                        <small>
                            (<%= listing.reviews.length %> reviews)
                        </small>
                <% } %>
            </div>

            <hr>

            <h4>All Reviews</h4>

            <% if (listing.reviews.length) { %>
                <div class="row">
                    <% listing.reviews.forEach((review) => { %>
                        <div class="col-md-6">
                            <div class="card">
                                <div class="card-body">
                                    <div class="d-flex gap-2">
                                        <small class="fw-bold">
                                            @<%= review.author.username %>
                                        </small>
                                        
                                        <p class="text-muted small mb-2">
                                            <%= review.createdAt.toLocaleDateString('en-IN') %>
                                        </p>

                                        <% if (curUser && review.author._id.equals(curUser._id)) { %>
                                            <form action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE" method="POST" class="ms-auto">
                                                <button class="review-trash">
                                                    <i class="fa-solid fa-trash" style="color: #fe424d;"></i>
                                                </button>
                                            </form>
                                        <% } %>
                                    </div>

                                    <h6>
                                        <%= "⭐".repeat(review.rating) %> 
                                    </h6>

                                    <p class="card-text">
                                        <%= review.comment %>
                                    </p>
                                </div>
                            </div>
                        </div>
                    <% }) %>
                </div>
            <% } else { %>
                <p class="text-muted">
                    No reviews yet. Be the first to provide review !
                </p>
            <% } %>

            <hr>

            <% if (curUser && listing.owner.equals(curUser._id)) { %>
                <div class="d-flex gap-2">
                    <a href="/listings/<%= listing._id %>/edit" class="btn btn-primary" method="GET">Edit</a>

                    <form action="/listings/<%= listing._id %>?_method=DELETE" method="POST">
                        <button class="btn btn-outline-danger" type="submit" id="deleteBtn">Remove Listing</button>
                    </form>
                </div>
            <% } %>
        </div>
    </div>
</div>

<script src="/js/ListingDetailedScript.js"></script>
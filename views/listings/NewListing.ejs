<% layout('layouts/BaseLayout.ejs') %>

<div class="row">
    <div class="col-md-8 offset-md-2">
        <h3 class="mb-4">Create New Listing</h3>

        <form action="/listings" method="POST">
            <div class="mb-3">
                <label class="form-label">Title</label>
                <input class="form-control" name="listing[title]" type="text" required>
            </div>
            <div class="mb-3">
                <label class="form-label">Description</label>
                <textarea class="form-control" name="listing[description]" required></textarea>
            </div>
            <div class="mb-3">
                <label class="form-label">Image URL</label>
                <input class="form-control" name="listing[image]" type="text">
            </div>
            <div class="row gx-2">
                <div class="col-7 mb-3">
                    <label class="form-label">Price</label>
                    <input class="form-control" name="listing[price]" min="0" type="number" required>
                </div>
                <div class="col-5 mb-3">
                    <label class="form-label">Currency</label>
                    <select class="form-select" name="listing[currency]">
                        <option value="INR">INR</option>
                        <option value="USD">USD</option>
                    </select>
                </div>
            </div>
            <div class="row gx-2">
                <div class="col-8 mb-3">
                    <label class="form-label">Location (City + State)</label>
                    <input class="form-control" name="listing[location]" placeholder="City, State" type="text" required>
                </div>
                <div class="col-4 mb-3">
                    <label class="form-label">Country</label>
                    <input class="form-control" name="listing[country]" type="text" required>
                </div>
            </div> 
            <div class="mb-3">
                <label class="form-label">Type</label>
                <select class="form-select" name="listing[type]">
                    <option value="Home">Home</option>
                    <option value="Hotel">Hotel</option>
                    <option value="Room">Room</option>
                    <option value="Apartment">Apartment</option>
                    <option value="Flat">Flat</option>
                    <option value="Villa">Villa</option>
                    <option value="GuestSuite">Guest Suite</option>
                </select>
            </div>
            <div class="mb-3">
                <label class="form-label">Amenities (comma-separated)</label>
                <input class="form-control" type="text" name="listing[amenities]" placeholder="WiFi, AC, Parking">
            </div>

            <div class="d-flex gap-2">
                <button id="cl-btn" class="btn" type="submit">Create Listing</button>
                <a href="/listings" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
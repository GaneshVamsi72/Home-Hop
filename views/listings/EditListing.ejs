<% layout('layouts/BaseLayout.ejs') %>

<div class="row">
    <div class="col-md-8 offset-md-2">
        <h3 class="mb-4">Edit Listing</h3>

        <form action="/listings/<%= listing.id %>?_method=PUT" method="POST" class="needs-validation" novalidate>
            <div class="mb-3">
                <label class="form-label">Title</label>
                <input class="form-control" name="listing[title]" value="<%= listing.title %>" type="text" required>
                <div class="invalid-feedback">Title is required!</div>
            </div>
            <div class="mb-3">
                <label class="form-label">Description</label>
                <textarea class="form-control" name="listing[description]" required><%= listing.description %></textarea>
                <div class="invalid-feedback">Description is required!</div>
            </div>
            <div class="mb-3">
                <label class="form-label">Image URL</label>
                <input class="form-control" name="listing[image]" value="<%= listing.image %>" type="url" placeholder="https://...">
            </div>
            <div class="row gx-2">
                <div class="col-7 mb-3">
                    <label class="form-label">Price</label>
                    <input class="form-control" name="listing[price]" value="<%= listing.price %>" min="0" type="number" required>
                    <div class="invalid-feedback">Valid Pricing is required!</div>
                </div>
                <div class="col-5 mb-3">
                    <label class="form-label">Currency</label>
                    <select class="form-control" name="listing[currency]">
                        <option value="INR" <%= listing.currency === "INR" ? "selected" : "" %>>INR</option>
                        <option value="USD" <%= listing.currency === "USD" ? "selected" : "" %>>USD</option>
                    </select>
                </div>
            </div>
            <div class="row gx-2">
                <div class="col-8 mb-3">
                    <label class="form-label">Location (City + State)</label>
                    <input class="form-control" name="listing[location]" value="<%= listing.location %>" type="text" required>
                    <div class="invalid-feedback">Location is required!</div>
                </div>
                <div class="col-4 mb-3">
                    <label class="form-label">Country</label>
                    <input class="form-control" name="listing[country]" value="<%= listing.country %>" type="text" required>
                    <div class="invalid-feedback">Country is required!</div> 
                </div>
            </div>
            <div class="mb-3">
                <label class="form-label">Type</label>
                <select class="form-control" name="listing[type]">
                    <option value="Home" <%= listing.type === "Home" ? "selected" : "" %>>Home</option>
                    <option value="Hotel" <%= listing.type === "Hotel" ? "selected" : "" %>>Hotel</option>
                    <option value="Room" <%= listing.type === "Room" ? "selected" : "" %>>Room</option>
                    <option value="Apartment" <%= listing.type === "Apartment" ? "selected" : "" %>>Apartment</option>
                    <option value="Flat" <%= listing.type === "Flat" ? "selected" : "" %>>Flat</option>
                    <option value="Villa" <%= listing.type === "Villa" ? "selected" : "" %>>Villa</option>
                    <option value="GuestSuite" <%= listing.type === "GuestSuite" ? "selected" : "" %>>Guest Suite</option>
                </select>
            </div>
            <div class="mb-3">
                <label class="form-label">Amenities (comma-separated)</label>
                <input class="form-control" type="text" name="listing[amenities]" value="<%= listing.amenities.join(', ') %>">
            </div>

            <div class="d-flex gap-2">
                <button id="ul-btn" class="btn" type="submit">Update Listing</button>
                <a href="/listings/<%= listing._id %>" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
